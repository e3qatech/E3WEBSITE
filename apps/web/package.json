{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint -d src",
    "seed:events": "tsx prisma/seed-events.ts",
    "seed:attractions": "tsx prisma/seed-attractions.ts",
    "seed:team": "tsx prisma/seed-team.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.2",
    "@prisma/client": "^5.14.0",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/xr": "6.1.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/cookie": "0.6.0",
    "@vercel/blob": "^2.5.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie": "^0.6.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.42.0",
    "gsap": "^3.15.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "three": "^0.185.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@size-limit/preset-app": "^11.1.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.185.0",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "size-limit": "^11.1.4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/pages/index-*.js",
      "limit": "200 kB"
    },
    {
      "path": ".next/static/chunks/pages/dashboard-*.js",
      "limit": "400 kB"
    },
    {
      "path": ".next/static/css/*.css",
      "limit": "50 kB"
    }
  ],
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
