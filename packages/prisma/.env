# E3 Website Environment Variables Template
# Copy this file to .env.local for development, or .env.production for deployment

# Base URLs
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_BOOKINGQUBE_URL="https://booking.e3.qa"

# API Keys & Secrets
# Used for verifying incoming webhooks from BookingQube
BOOKINGQUBE_WEBHOOK_SECRET="your_webhook_secret_here"
# Used for backend API calls to BookingQube
BOOKINGQUBE_API_KEY="your_api_key_here"

# Database Configuration (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/e3_db?schema=public"

# Redis Configuration (For internal Socket.io pub/sub or API caching)
REDIS_URL="redis://localhost:6379"

# Security & Authentication
# Run `openssl rand -base64 32` to generate a secure secret
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Telemetry (Optional)
# NEXT_TELEMETRY_DISABLED=1
# ANALYZE=false
